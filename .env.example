# Origen de la Plataforma de Servicio / apps (sin barra final)
# Producción Relatic:
VITE_NODEONE_BASE_URL=https://apps.relatic.org

# Inicio de sesión (sin barra final). Por defecto el código usa https://miembros.relatic.org/login
# VITE_NODEONE_LOGIN_BASE_URL=https://miembros.relatic.org

# URL de entrada a la app (catálogo de servicios, inicio rápido). Si no se define,
# el código usa {VITE_NODEONE_BASE_URL}/services
VITE_CAMPUS_URL=https://apps.relatic.org/services

# Blog / noticias (si aplica)
VITE_BLOG_URL=https://relaticpanama.org/_blog/
